#!/usr/bin/env bash
# 提交测试门 + 密钥防泄漏扫描(上线档 🟡)。
# 正本在 scripts/hooks/;安装 = cp scripts/hooks/pre-commit .git/hooks/ && chmod +x
set -uo pipefail

# ── 1. 密钥防泄漏扫描(只扫本次暂存的新增行;挡手滑,不挡存心) ──
secret_patterns=(
  '(api[_-]?key|apikey|secret|token|password)["'"'"']?\s*[:=]\s*["'"'"'][A-Za-z0-9_\-\.]{16,}'
  '[0-9a-f]{32}\.[A-Za-z0-9]{6,}'          # 智谱 key 形态
  'sk-[A-Za-z0-9]{20,}'                     # OpenAI 风格
  'AKIA[0-9A-Z]{16}'                        # AWS
  '-----BEGIN [A-Z ]*PRIVATE KEY'
)
staged_added=$(git diff --cached -U0 -- . ':(exclude)package-lock.json' | grep '^+' | grep -v '^+++ ' || true)  # 剔除 diff 头行,防路径名误拦(GLM 20260717-004 [2])
for pat in "${secret_patterns[@]}"; do
  hit=$(printf '%s\n' "$staged_added" | grep -inE -e "$pat" | head -3 || true)  # -e:防 pattern 以 - 开头被当选项
  if [ -n "$hit" ]; then
    echo "[密钥扫描门] 暂存内容疑似含密钥,已阻止提交:" >&2
    printf '%s\n' "$hit" >&2
    echo "             真密钥→移去 .env / wrangler secrets;误报→git commit --no-verify(留痕自担)" >&2
    exit 1
  fi
done

# ── 2. 机器闸门门(防失真硬线,tech-debt D6):每集金句必过三联,不过 → 阻止提交 ──
if command -v node >/dev/null 2>&1; then
  echo "[机器闸门门] 运行: node scripts/gate-all.mjs"
  if ! node scripts/gate-all.mjs; then
    echo "[机器闸门门] 存在失真金句 → 已阻止提交。修金句(scripts/repair-quotes.mjs / 重浓缩)再提交。" >&2
    echo "             (如确需绕过:git commit --no-verify —— 留痕自担)" >&2
    exit 1
  fi
else
  echo "[机器闸门门] ⚠️ 未找到 node,跳过金句校验(不应发生:测试门也需 node)" >&2
fi

# ── 3. 提交测试门:测试不绿 → 阻止提交 ──
TEST_CMD="${TEST_CMD:-npm test --silent}"
echo "[提交测试门] 运行: $TEST_CMD"
if eval "$TEST_CMD"; then
  echo "[提交测试门] 测试通过 ✅"
  exit 0
else
  echo "[提交测试门] 测试未通过 → 已阻止提交。修绿再提交。" >&2
  echo "             (如确需绕过:git commit --no-verify —— 会留下未验证的提交,不建议)" >&2
  exit 1
fi
