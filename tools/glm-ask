#!/usr/bin/env python3
"""glm-ask — 直接调用智谱 GLM-5.2（Anthropic 兼容入口），给一段 prompt，打印回答。

本仓库自带副本（C7b 无人值守:GitHub Actions runner 上没有全局 ~/.local/bin/glm-ask）。
与全局版逻辑一致，只加一条:key 优先读环境变量 ZHIPU_API_KEY（GitHub Secret 注入、不落盘），
读不到再回退 ~/.config/zhipu/api_key（本地开发照旧）。

用法:
  glm-ask "你的问题"
  echo "一大段内容" | glm-ask
  glm-ask --model glm-5.2 "问题"           # 指定模型，默认 glm-5.2
  glm-ask --system "你是…" "问题"          # 加 system 提示
  glm-ask --max-tokens 8192 "问题"
"""
import sys, os, json, urllib.request, urllib.error

KEY_FILE = os.path.expanduser("~/.config/zhipu/api_key")
ENDPOINT = "https://open.bigmodel.cn/api/anthropic/v1/messages"


def read_key():
    # 优先环境变量(CI 走 GitHub Secret,不落盘);回退 key 文件(本地开发)。
    env = os.environ.get("ZHIPU_API_KEY", "").strip()
    if env:
        return env
    try:
        with open(KEY_FILE) as f:
            return f.read().strip()
    except FileNotFoundError:
        sys.exit(f"找不到智谱 key:环境变量 ZHIPU_API_KEY 未设 且 无 key 文件 {KEY_FILE}")


def main():
    args = sys.argv[1:]
    model = "glm-5.2"
    system = None
    max_tokens = 4096
    rest = []
    i = 0
    while i < len(args):
        a = args[i]
        if a == "--model":
            model = args[i + 1]; i += 2
        elif a == "--system":
            system = args[i + 1]; i += 2
        elif a == "--max-tokens":
            max_tokens = int(args[i + 1]); i += 2
        else:
            rest.append(a); i += 1

    prompt = " ".join(rest).strip()
    if not prompt and not sys.stdin.isatty():
        prompt = sys.stdin.read().strip()
    if not prompt:
        sys.exit('用法: glm-ask "你的问题"  或  echo 内容 | glm-ask')

    body = {
        "model": model,
        "max_tokens": max_tokens,
        "messages": [{"role": "user", "content": prompt}],
    }
    if system:
        body["system"] = system

    req = urllib.request.Request(
        ENDPOINT,
        data=json.dumps(body).encode("utf-8"),
        headers={
            "x-api-key": read_key(),
            "anthropic-version": "2023-06-01",
            "content-type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=180) as r:
            data = json.load(r)
    except urllib.error.HTTPError as e:
        sys.exit(f"[HTTP {e.code}] {e.read().decode('utf-8', 'replace')}")
    except urllib.error.URLError as e:
        sys.exit(f"网络错误: {e}")

    text = "".join(
        b.get("text", "") for b in data.get("content", []) if b.get("type") == "text"
    )
    print(text)
    u = data.get("usage", {})
    if u:
        sys.stderr.write(
            f"\n[{data.get('model','?')} | in {u.get('input_tokens','?')} / out {u.get('output_tokens','?')} tokens]\n"
        )


if __name__ == "__main__":
    main()
